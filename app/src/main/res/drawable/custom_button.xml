<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/gradient_start_alpha"
                android:endColor="@color/gradient_end_alpha"
                android:angle="135"/>
            <corners android:radius="30dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/gradient_end_alpha"
                android:endColor="@color/gradient_start_alpha"
                android:angle="135"/>
            <corners android:radius="30dp"/>
        </shape>
    </item>
</selector>
