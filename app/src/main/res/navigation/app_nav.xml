<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/app_nav"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@id/profileFragment"
        android:name="com.example.nocturnevpn.view.fragment.profileFragment"
        android:label="fragment_profile"
        tools:layout="@layout/fragment_profile" >
        <action
            android:id="@+id/action_profileFragment_to_premiumFragment"
            app:destination="@id/premiumFragment" />
        <action
            android:id="@+id/action_profileFragment_to_historyFragment"
            app:destination="@id/historyFragment" />
        <action
            android:id="@+id/action_profileFragment_to_editUserInfoFragment"
            app:destination="@id/editUserInfoFragment" />
    </fragment>

    <fragment
        android:id="@id/homeFragment"
        android:name="com.example.nocturnevpn.view.fragment.HomeFragment"
        android:label="fragment_home"
        tools:layout="@layout/fragment_home" >
        <action
            android:id="@+id/action_homeFragment_to_premiumFragment"
            app:destination="@id/premiumFragment" />
    </fragment>

    <fragment
        android:id="@id/settingFragment3"
        android:name="com.example.nocturnevpn.view.fragment.settingFragment"
        android:label="fragment_setting"
        tools:layout="@layout/fragment_setting" >

        <action
            android:id="@+id/action_settingFragment3_to_advanceSetttingFragment"
            app:destination="@id/advanceSetttingFragment" />
        <action
            android:id="@+id/action_settingFragment3_to_appIconFragment"
            app:destination="@id/appIconFragment" />
        <action
            android:id="@+id/action_settingFragment3_to_helpCenterFragment"
            app:destination="@id/helpCenterFragment" />
    </fragment>
    <fragment
        android:id="@+id/advanceSetttingFragment"
        android:name="com.example.nocturnevpn.view.fragment.AdvanceSetttingFragment"
        android:label="fragment_advance_settting"
        tools:layout="@layout/fragment_advance_settting" />
    <fragment
        android:id="@+id/premiumFragment"
        android:name="com.example.nocturnevpn.view.fragment.PremiumFragment"
        android:label="fragment_premium"
        tools:layout="@layout/fragment_premium" />
    <fragment
        android:id="@+id/appIconFragment"
        android:name="com.example.nocturnevpn.view.fragment.appIconFragment"
        android:label="fragment_app_icon"
        tools:layout="@layout/fragment_app_icon" />
    <fragment
        android:id="@+id/historyFragment"
        android:name="com.example.nocturnevpn.view.fragment.HistoryFragment"
        android:label="fragment_history"
        tools:layout="@layout/fragment_history" />
    <fragment
        android:id="@+id/helpCenterFragment"
        android:name="com.example.nocturnevpn.view.fragment.HelpCenterFragment"
        android:label="HelpCenterFragment" />
    <fragment
        android:id="@+id/editUserInfoFragment"
        android:name="com.example.nocturnevpn.view.fragment.EditUserInfoFragment"
        android:label="EditUserInfoFragment"
        tools:layout="@layout/fragment_edit_user_info" />

</navigation>