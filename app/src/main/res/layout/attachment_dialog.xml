<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:layout_marginStart="24dp"
    android:layout_marginEnd="24dp"
    app:cardCornerRadius="10dp"
    app:cardUseCompatPadding="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="16dp">

        <TextView
            android:id="@+id/attachment_dialog_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Add Attachment"
            android:textAppearance="@style/TextAppearance.AppCompat.Medium"
            android:textColor="@color/black"
            android:gravity="center"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/attachment_dialog_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Choose an option to add attachments to your report"
            android:textColor="@color/gray"
            android:textAlignment="center"
            android:paddingTop="4dp"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/attachment_dialog_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Choose from Gallery Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_choose_gallery"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Choose from Gallery"
            android:textColor="@color/white"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/strong_violet"
            app:icon="@drawable/ic_bug"
            app:iconTint="@color/white"
            app:layout_constraintTop_toBottomOf="@id/attachment_dialog_subtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp" />

        <!-- Remove All Attachments Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_remove_attachments"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Remove All Attachments"
            android:textColor="@color/strong_violet"
            app:cornerRadius="12dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/strong_violet"
            app:icon="@drawable/ic_delete"
            app:iconTint="@color/strong_violet"
            app:layout_constraintTop_toBottomOf="@id/btn_choose_gallery"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp" />

        <!-- Cancel Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="@color/gray"
            app:cornerRadius="12dp"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            app:layout_constraintTop_toBottomOf="@id/btn_remove_attachments"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginTop="8dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView> 