<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    app:cardElevation="12dp"
    app:cardUseCompatPadding="true"
    app:cardBackgroundColor="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/subscription_loading_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="32dp">

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/subscription_loading_lottie"
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:lottie_rawRes="@raw/loader"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/subscription_loading_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Verifying Subscription"
            android:textAlignment="center"
            android:textColor="@color/strong_violet"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/subscription_loading_lottie"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/subscription_loading_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Please wait while we verify your purchase with our backend server..."
            android:textColor="@color/text_secondary_gray"
            android:textAlignment="center"
            android:paddingTop="8dp"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            app:layout_constraintTop_toBottomOf="@id/subscription_loading_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="8dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
