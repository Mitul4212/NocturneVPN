<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />


    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:extractNativeLibs="true"
        android:fullBackupContent="@xml/backup_rules"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NocturneVPN"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">
        <activity
            android:name=".view.activitys.AppAuthActivity"
            android:exported="false" />
        <activity
            android:name=".view.activitys.ReportIssueActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".view.activitys.ChangeServerActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>
<!--        <activity-->
<!--            android:name=".ServerActivity"-->
<!--            android:exported="false"-->
<!--            android:screenOrientation="portrait" />-->
        <activity
            android:name=".view.activitys.HomeActivity"
            android:exported="true"
            android:screenOrientation="portrait">
<!--            <intent-filter>-->
<!--                <action android:name="android.intent.action.MAIN" />-->

<!--                <category android:name="android.intent.category.LAUNCHER" />-->
<!--            </intent-filter>-->
        </activity>

        <!-- Default Icon -->
        <activity-alias
            android:name=".DefaultAlias"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/app_name"
            android:targetActivity=".view.activitys.HomeActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Icon 2 -->
        <activity-alias
            android:name=".Icon2Alias"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_dark"
            android:label="@string/app_name"
            android:targetActivity=".view.activitys.HomeActivity" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Icon 3 -->
        <activity-alias
            android:name=".Icon3Alias"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_dark_2"
            android:label="@string/app_name"
            android:targetActivity=".view.activitys.HomeActivity" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Icon 4 -->
        <activity-alias
            android:name=".Icon4Alias"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_3d_1"
            android:label="@string/app_name"
            android:targetActivity=".view.activitys.HomeActivity" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Icon 5 -->
        <activity-alias
            android:name=".Icon5Alias"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_3d_2"
            android:label="@string/app_name"
            android:targetActivity=".view.activitys.HomeActivity" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Icon 6 -->
        <activity-alias
            android:name=".Icon6Alias"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_3d_retro"
            android:label="@string/app_name"
            android:targetActivity=".view.activitys.HomeActivity" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <service
            android:name="de.blinkt.openvpn.core.OpenVPNService"
            android:exported="false"
            android:permission="android.permission.BIND_VPN_SERVICE">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>
    </application>

</manifest>